{
  "name": "laizy",
  "version": "0.1.0",
  "description": "Open-source orchestration layer for Claude Code, Codex, OpenClaw, and other coding agents.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "laizy": "dist/src/index.js"
  },
  "main": "dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiaolongGao521/Laizy.git"
  },
  "homepage": "https://github.com/XiaolongGao521/Laizy#readme",
  "bugs": {
    "url": "https://github.com/XiaolongGao521/Laizy/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "claude-code",
    "codex",
    "openclaw",
    "automation",
    "cli"
  ],
  "scripts": {
    "build": "/usr/bin/node scripts/build-check.mjs",
    "compile": "/usr/bin/npx tsc -p tsconfig.json",
    "typecheck": "/usr/bin/npx tsc -p tsconfig.json --noEmit",
    "prepack": "/usr/bin/npx tsc -p tsconfig.json",
    "smoke:init": "/usr/bin/npx tsc -p tsconfig.json && node dist/src/index.js init-run --goal \"smoke test\" --plan examples/demo-implementation-plan.md --out /tmp/laizy-smoke-run.json",
    "ralph:plan": "/root/.openclaw/workspace/ralph-loop.sh --repo \"$PWD\" --mode planning",
    "ralph:build": "/root/.openclaw/workspace/ralph-loop.sh --repo \"$PWD\" --mode build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
